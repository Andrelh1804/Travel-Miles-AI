# ============================================================
# TravelMiles AI — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA comite arquivos .env com valores reais.
# ============================================================

# ─── Servidor ────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ─── Supabase ────────────────────────────────────────────────
# Obtenha em: https://supabase.com → Project → Settings → API
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# ─── Web (Next.js) ───────────────────────────────────────────
# Prefixo NEXT_PUBLIC_ expõe ao browser
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Segurança ───────────────────────────────────────────────
SESSION_SECRET=<string-aleatória-de-ao-menos-32-caracteres>
ALLOWED_ORIGINS=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Logs ────────────────────────────────────────────────────
LOG_LEVEL=log

# ─── Pagamentos (Fase 4) ─────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# MERCADO_PAGO_ACCESS_TOKEN=
